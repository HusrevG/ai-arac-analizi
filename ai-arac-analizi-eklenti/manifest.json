{
  "manifest_version": 3,
  "name": "AI Araç Analizi",
  "version": "11.31.0",
  "description": "Sahibinden araç verilerini Streamlit AI Araç Analizi uygulamasına aktarır; Trink Sat ve VavaCars doldurma yardımcıları içerir.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.sahibinden.com/*",
    "https://*.sahibinden.com/*",
    "https://www.arabam.com/*",
    "https://*.arabam.com/*",
    "https://tr.vava.cars/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.sahibinden.com/*",
        "https://*.sahibinden.com/*",
        "https://www.arabam.com/*",
        "https://*.arabam.com/*",
        "https://tr.vava.cars/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
